APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
ALLOWED_ORIGINS_RAW=http://localhost:3000
REQUIRE_AUTH=false
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knowledge_hub
MAX_UPLOAD_SIZE_MB=15
UPLOAD_DIR=./data/uploads
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_LIMIT=6
RETRIEVAL_MIN_SCORE=0.3
RETRIEVAL_MIN_TERM_OVERLAP=1
ANSWER_MIN_SCORE=0.35
GENERATION_PROVIDER=auto
EMBEDDING_PROVIDER=auto
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
ALLOW_FALLBACK_MODELS=true
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=knowledge-hub
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
RUN_DB_MIGRATIONS_ON_STARTUP=false
SUPABASE_URL=
SUPABASE_ANON_KEY=

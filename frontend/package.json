{
  "name": "knowledge-hub-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "printf 'Knowledge Hub frontend starting\\n  URL: http://127.0.0.1:3000\\n  API base: %s\\n  Supabase URL present: %s\\n' \"${API_BASE_URL:-http://localhost:8000}\" \"$( [ -n \"${NEXT_PUBLIC_SUPABASE_URL:-}\" ] && echo yes || echo no )\" && next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "find .next/types -name '* 2.*' -delete 2>/dev/null || true; tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.56.0",
    "@tanstack/react-query": "^5.74.4",
    "@tanstack/react-query-devtools": "^5.74.4",
    "clsx": "^2.1.1",
    "next": "15.5.14",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.14.1",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.5.14",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.1"
  }
}
